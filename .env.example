# Copiar a .env.local y rellenar (no subir secretos al repositorio).

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Flow — único medio de pago en línea (SÉ TMS y otras órdenes). Credenciales de prueba: https://developers.flow.cl/
FLOW_API_KEY=
FLOW_SECRET_KEY=
# Producción (default en código): https://www.flow.cl/api — Sandbox: https://sandbox.flow.cl/api
# FLOW_API_URL=https://www.flow.cl/api
